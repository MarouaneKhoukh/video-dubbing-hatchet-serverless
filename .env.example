# Credentials only. Every other setting (image URIs, model names, per-stage
# compute / batch_size, target language, Hatchet orchestration) defaults in
# src/pipeline/config.py. Power users can still override any field by adding it
# here — pydantic-settings honours nested env vars via double-underscore.
#
# Prefixes:
#   PIPELINE__…   what the pipeline does (e.g. PIPELINE__TRANSCRIBE__MODEL=large-v3)
#   STAGES__…     Hatchet per-stage orchestration (e.g. STAGES__TRANSCRIBE__RETRIES=5)
#   (no prefix)   workflow-wide knobs (e.g. WORKFLOW_NAME, TIMEOUT_BUFFER_S)

# ── Hatchet ────────────────────────────────────────────────────────────────────
# Get this from the Hatchet dashboard → Settings → API Keys.
# Self-hosted: http://localhost:8090 → create a key there.
HATCHET_CLIENT_TOKEN=your_hatchet_token_here

# ── Nebius ─────────────────────────────────────────────────────────────────────
NEBIUS_IAM_TOKEN=your_nebius_iam_token_here
NEBIUS_PROJECT_ID=project-xxxxxxxxxxxx
NEBIUS_SUBNET_ID=vpcsubnet-xxxxxxxxxxxx

# ── Object storage (S3-compatible) ─────────────────────────────────────────────
NEBIUS_BUCKET_ID=storagebucket-xxxxxxxxxxxx
NEBIUS_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud
