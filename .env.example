# ── Hatchet ────────────────────────────────────────────────────────────────────
# Get this from the Hatchet dashboard → Settings → API Keys
# If self-hosting: http://localhost:8090 → create a key there
HATCHET_CLIENT_TOKEN=your_hatchet_token_here

# ── Nebius ─────────────────────────────────────────────────────────────────────
NEBIUS_IAM_TOKEN=your_nebius_iam_token_here
NEBIUS_PROJECT_ID=project-xxxxxxxxxxxx
NEBIUS_SUBNET_ID=vpcsubnet-xxxxxxxxxxxx

# ── Object storage (S3-compatible) ─────────────────────────────────────────────
NEBIUS_BUCKET_ID=storagebucket-xxxxxxxxxxxx
NEBIUS_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_ENDPOINT_URL=https://storage.eu-north1.nebius.cloud

# ── Pipeline settings ──────────────────────────────────────────────────────────
# Language code for dubbing target (e.g. de, fr, es)
TARGET_LANG=de

# Docker images for workload jobs (push these before running)
WHISPER_IMAGE=ghcr.io/your-org/nebius-whisper:latest
TRANSLATE_IMAGE=ghcr.io/your-org/nebius-translate:latest
TTS_IMAGE=ghcr.io/your-org/nebius-tts:latest

# Whisper model size: tiny, base, small, medium, large, turbo
WHISPER_MODEL=turbo

# Coqui TTS model for target language
TTS_MODEL=tts_models/de/thorsten/vits
